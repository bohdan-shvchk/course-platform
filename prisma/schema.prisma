generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  student
}

model User {
  id         String    @id @db.Uuid
  email      String    @unique
  role       Role      @default(student)
  fullName   String?   @map("full_name")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastSeenAt DateTime? @map("last_seen_at")

  invitationsCreated Invitation[]     @relation("CreatedBy")
  invitationUsed     Invitation?      @relation("UsedBy")
  enrollment         Enrollment?
  progress           LessonProgress[]

  @@map("users")
}

model Invitation {
  id        String    @id @default(uuid()) @db.Uuid
  token     String    @unique
  email     String
  createdBy String    @map("created_by") @db.Uuid
  usedBy    String?   @unique @map("used_by") @db.Uuid
  usedAt    DateTime? @map("used_at")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  creator    User        @relation("CreatedBy", fields: [createdBy], references: [id])
  usedByUser User?       @relation("UsedBy", fields: [usedBy], references: [id])
  enrollment Enrollment?

  @@map("invitations")
}

model Enrollment {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @unique @map("user_id") @db.Uuid
  enrolledAt   DateTime  @default(now()) @map("enrolled_at")
  expiresAt    DateTime? @map("expires_at")
  invitationId String?   @unique @map("invitation_id") @db.Uuid

  user       User        @relation(fields: [userId], references: [id])
  invitation Invitation? @relation(fields: [invitationId], references: [id])

  @@map("enrollments")
}

model Module {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String?
  position    Int
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  lessons Lesson[]

  @@map("modules")
}

model Lesson {
  id             String   @id @default(uuid()) @db.Uuid
  moduleId       String   @map("module_id") @db.Uuid
  title          String
  description    String?
  position       Int
  isPublished    Boolean  @default(false) @map("is_published")
  videoId        String?  @map("video_id")
  videoLibraryId String?  @map("video_library_id")
  videoDuration  Int?     @map("video_duration")
  videoThumbnail String?  @map("video_thumbnail")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  module      Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  attachments Attachment[]
  progress    LessonProgress[]

  @@map("lessons")
}

model Attachment {
  id          String   @id @default(uuid()) @db.Uuid
  lessonId    String   @map("lesson_id") @db.Uuid
  filename    String
  storagePath String   @map("storage_path")
  mimeType    String   @map("mime_type")
  sizeBytes   BigInt   @map("size_bytes")
  position    Int
  createdAt   DateTime @default(now()) @map("created_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model Registration {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  fullName  String   @map("full_name")
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("registrations")
}

model LessonProgress {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  lessonId      String    @map("lesson_id") @db.Uuid
  isCompleted   Boolean   @default(false) @map("is_completed")
  watchSeconds  Int       @default(0) @map("watch_seconds")
  completedAt   DateTime? @map("completed_at")
  lastWatchedAt DateTime? @map("last_watched_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}
